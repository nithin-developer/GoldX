# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/trading_signals

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=Trading Signals API
DEBUG=True
API_V1_PREFIX=/api/v1
UPLOADS_DIR=./uploads
VERIFICATION_MAX_FILE_SIZE_MB=15

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:8080"]
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Admin
ADMIN_EMAIL=admin@tradingsignals.com
ADMIN_PASSWORD=admin123456
